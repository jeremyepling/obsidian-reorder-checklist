{
  "name": "obsidian-reorder-checklist",
  "version": "1.0.2",
  "description": "Obsidian plugin: sort every checklist on the page — unchecked on top, checked at bottom — respecting indentation, headings, and ordered-list numbering.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "checklist",
    "todo"
  ],
  "author": "Jeremy Epling",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
